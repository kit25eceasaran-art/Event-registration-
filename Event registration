<!DOCTYPE html>  <html lang="en">  
<head>  
<meta charset="UTF-8">  
<title>Event Registration Pro</title>  <style>  
/* 🔥 Animated Fire Background */  
body {  
    margin: 0;  
    font-family: Arial, sans-serif;  
    height: 100vh;  
    display: flex;  
    justify-content: center;  
    align-items: center;  
    background: black;  
    overflow: hidden;  
}  
  
/* Fire effect */  
body::before {  
    content: "";  
    position: absolute;  
    width: 100%;  
    height: 100%;  
    background: radial-gradient(circle, rgba(255,80,0,0.8), black 70%);  
    animation: fire 2s infinite alternate;  
    z-index: -1;  
}  
  
@keyframes fire {  
    0% { filter: hue-rotate(0deg) brightness(1); }  
    100% { filter: hue-rotate(40deg) brightness(1.3); }  
}  
  
/* 📦 Form Container */  
.container {  
    background: rgba(255,255,255,0.95);  
    padding: 25px;  
    border-radius: 12px;  
    width: 350px;  
    box-shadow: 0 0 20px orange;  
    animation: float 3s infinite ease-in-out;  
}  
  
@keyframes float {  
    0%,100% { transform: translateY(0); }  
    50% { transform: translateY(-10px); }  
}  
  
h2 {  
    text-align: center;  
    color: #ff4500;  
}  
  
/* Inputs */  
input {  
    width: 100%;  
    padding: 10px;  
    margin: 8px 0;  
    border-radius: 6px;  
    border: 1px solid #ccc;  
    outline: none;  
}  
  
button {  
    width: 100%;  
    padding: 10px;  
    background: linear-gradient(to right, #ff4500, #ff8c00);  
    color: white;  
    border: none;  
    border-radius: 6px;  
    cursor: pointer;  
    font-weight: bold;  
}  
  
button:hover {  
    transform: scale(1.05);  
}  
  
/* Messages */  
.error {  
    color: red;  
    font-size: 12px;  
}  
  
.success {  
    color: green;  
    text-align: center;  
    margin-top: 10px;  
    font-weight: bold;  
}  
  
/* 📱 Mobile Responsive */  
@media (max-width: 500px) {  
    .container {  
        width: 90%;  
    }  
}  
</style>  </head>  <body>  <div class="container">  
    <h2>🔥 Event Registration</h2>  <form id="form">  
    <input type="text" id="name" placeholder="Enter Name">  
    <div class="error" id="nameError"></div>  

    <input type="email" id="email" placeholder="Enter Email">  
    <div class="error" id="emailError"></div>  

    <input type="number" id="seats" placeholder="Seats (Max 5)">  
    <div class="error" id="seatError"></div>  

    <button type="submit">Register</button>  
</form>  

<div class="success" id="successMsg"></div>

</div>  <script>  
let availableSeats = 20;  
  
document.getElementById("form").addEventListener("submit", function(e) {  
    e.preventDefault();  
  
    let name = document.getElementById("name").value;  
    let email = document.getElementById("email").value;  
    let seats = Number(document.getElementById("seats").value);  
  
    // Clear messages  
    document.getElementById("nameError").innerText = "";  
    document.getElementById("emailError").innerText = "";  
    document.getElementById("seatError").innerText = "";  
    document.getElementById("successMsg").innerText = "";  
  
    let valid = true;  
  
    // Validation  
    if (name === "") {  
        document.getElementById("nameError").innerText = "Name required";  
        valid = false;  
    }  
  
    if (email === "" || !email.includes("@")) {  
        document.getElementById("emailError").innerText = "Valid email required";  
        valid = false;  
    }  
  
    if (seats <= 0 || seats > 5) {  
        document.getElementById("seatError").innerText = "Seats must be 1–5";  
        valid = false;  
    } else if (seats > availableSeats) {  
        document.getElementById("seatError").innerText = "Not enough seats available";  
        valid = false;  
    }  
  
    // Success  
    if (valid) {  
        availableSeats -= seats;  
  
        document.getElementById("successMsg").innerText =  
            "✅ Registered! Remaining seats: " + availableSeats;  
  
        document.getElementById("form").reset();  
    }  
});  
</script>  </body>  
</html> 
